{
  "name": "wdio-appium-boilerplate",
  "type": "module",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mysql": "^2.15.27",
    "@types/node": "^25.5.0",
    "@wdio/allure-reporter": "^9.27.0",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/cucumber-framework": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "allure-commandline": "^2.38.1",
    "allure-single-html-file-js": "^0.0.6",
    "appium-uiautomator2-driver": "^7.1.0",
    "expect-webdriverio": "^5.6.5",
    "js-yaml": "^4.1.0",
    "mysql": "^2.18.1"
  },
  "scripts": {
    "wdio": "wdio run ./wdio.conf.ts",
    "test:android": "ENV=production PLATFORM=Android wdio run ./wdio.conf.ts",
    "test:ios": "ENV=staging PLATFORM=iOS wdio run ./wdio.conf.ts",
    "allure-generate": "./node_modules/.bin/allure generate allure-results --clean -o allure-report",
    "allure-open": "./node_modules/.bin/allure open ./allure-report",
    "allure-export": "node ./node_modules/allure-single-html-file-js/combine.js ./allure-report",
    "allure-delete": "rm -rf ./allure-results ./allure-report ./allure-screenshot"
  }
}
